            <span class="text-[10px] tracking-[0.3em] uppercase">Scroll</span>
            <div class="w-px h-12 bg-gradient-to-b from-gold to-transparent"></div>
        </div>
    </section>

    <!-- Marquee Section -->
    <div class="border-y border-white/10 py-6 bg-black/50 backdrop-blur-sm">
        <div class="marquee-container">
            <div class="marquee-content text-gold font-serif text-2xl md:text-4xl italic">
                <span class="mx-8">Discretion Guaranteed</span>
                <span class="mx-8 text-white/20">•</span>
                <span class="mx-8">Dubai Wide Service</span>
                <span class="mx-8 text-white/20">•</span>
                <span class="mx-8">By Appointment Only</span>
                <span class="mx-8 text-white/20">•</span>
                <span class="mx-8">Private Residence Visits</span>
                <span class="mx-8 text-white/20">•</span>
                <span class="mx-8">Discretion Guaranteed</span>
                <span class="mx-8 text-white/20">•</span>
                <span class="mx-8">Dubai Wide Service</span>
                <span class="mx-8 text-white/20">•</span>
                <span class="mx-8">By Appointment Only</span>
                <span class="mx-8 text-white/20">•</span>
                <span class="mx-8">Private Residence Visits</span>
                <span class="mx-8 text-white/20">•</span>
