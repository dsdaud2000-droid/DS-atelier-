                            <span class="text-xs tracking-widest uppercase text-gray-500">45 min</span>
                        </div>
                    </div>
                </div>

                <!-- Service 3 -->
                <div class="service-card group border border-white/10 p-12 bg-black/40 backdrop-blur-sm relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-b from-gold/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <div class="relative z-10">
