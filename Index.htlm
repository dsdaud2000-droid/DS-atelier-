    <!-- Coverage Area -->
    <section class="py-20 bg-[#0a0a0a] border-y border-white/5">
        <div class="container mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-center gap-8">
                <div>
                    <h3 class="font-serif text-3xl mb-2">Dubai Coverage</h3>
                    <p class="text-gray-500">Serving all premium residential areas</p>
                </div>
                <div class="flex flex-wrap gap-4 justify-center">
                    <span class="px-6 py-2 border border-white/10 text-sm tracking-widest uppercase">Palm Jumeirah</span>
                    <span class="px-6 py-2 border border-white/10 text-sm tracking-widest uppercase">Emirates Hills</span>
                    <span class="px-6 py-2 border border-white/10 text-sm tracking-widest uppercase">Downtown Dubai</span>
                    <span class="px-6 py-2 border border-white/10 text-sm tracking-widest uppercase">Dubai Hills</span>
                    <span class="px-6 py-2 border border-white/10 text-sm tracking-widest uppercase">Jumeirah</span>
                    <span class="px-6 py-2 border border-gold/30 text-gold text-sm tracking-widest uppercase">+ All Areas</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section class="py-32 relative" id="contact">
        <div class="container mx-auto px-6">
            <div class="max-w-4xl mx-auto text-center">
                <p class="text-gold text-xs tracking-[0.5em] uppercase mb-6">By Appointment Only</p>
                <h2 class="font-serif text-5xl md:text-7xl mb-8">Begin Your <span class="gold-gradient italic">Experience</span></h2>
                <p class="text-gray-400 text-lg mb-12 max-w-2xl mx-auto">
                    Contact us exclusively via WhatsApp for bookings and inquiries. 
                    We respond to all messages within the hour during business hours.
                </p>

                <div class="grid md:grid-cols-2 gap-8 mb-16">
                    <div class="p-8 border border-white/10 bg-white/5 backdrop-blur-sm">
                        <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-4">WhatsApp</p>
                        <a href="https://wa.me/971522346299" target="_blank" class="text-2xl md:text-3xl font-serif text-gold hover:text-white transition-colors">
                            +971 52 234 6299
                        </a>
                        <p class="text-xs text-gray-600 mt-2">Preferred method of contact</p>
                    </div>
                    
                    <div class="p-8 border border-white/10 bg-white/5 backdrop-blur-sm">
                        <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-4">Availability</p>
                        <p class="text-xl font-serif text-white">Daily</p>
                        <p class="text-sm text-gray-400 mt-2">10:00 AM — 10:00 PM</p>
                    </div>
                </div>

                <a href="https://wa.me/971522346299" target="_blank" class="btn-luxury inline-flex items-center gap-4 bg-gold text-black px-16 py-6 text-sm tracking-[0.3em] uppercase font-medium hover:shadow-[0_0_40px_rgba(212,175,55,0.4)] transition-all group">
                    <span>Book via WhatsApp</span>
                    <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                </a>

                <p class="text-xs text-gray-600 mt-8 italic">
                    * 24-hour advance booking required. Cancellation policy applies.
                </p>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-white/10 py-12 bg-black">
        <div class="container mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="text-center md:text-left">
                    <h4 class="font-serif text-2xl text-gold mb-2">DS ATELIER</h4>
                    <p class="text-xs tracking-[0.2em] text-gray-600 uppercase">Private Grooming Atelier</p>
                </div>
                
                <div class="text-center md:text-right">
                    <p class="text-xs text-gray-600 mb-2">© 2024 DS Atelier. All rights reserved.</p>
                    <p class="text-[10px] text-gray-700 uppercase tracking-widest">Dubai, United Arab Emirates</p>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // Loading Screen
        window.addEventListener('load', () => {
            setTimeout(() => {
                document.getElementById('loader').classList.add('loader-hidden');
                initAnimations();
            }, 1500);
        });

        // Custom Cursor
        const cursorDot = document.querySelector('.cursor-dot');
        const cursorOutline = document.querySelector('.cursor-outline');
        
        window.addEventListener('mousemove', (e) => {
            const posX = e.clientX;
            const posY = e.clientY;
            
            cursorDot.style.left = `${posX}px`;
            cursorDot.style.top = `${posY}px`;
            
            cursorOutline.animate({
                left: `${posX}px`,
                top: `${posY}px`
            }, { duration: 500, fill: "forwards" });
        });

        // Hover effect for cursor
        const interactiveElements = document.querySelectorAll('a, button, .service-card');
        interactiveElements.forEach(el => {
            el.addEventListener('mouseenter', () => cursorOutline.classList.add('hover'));
            el.addEventListener('mouseleave', () => cursorOutline.classList.remove('hover'));
        });

        // GSAP Animations
        function initAnimations() {
            gsap.registerPlugin(ScrollTrigger);

            // Hero Animations
            gsap.to("#hero-subtitle", {
                opacity: 1,
                y: 0,
                duration: 1,
                delay: 0.2,
                ease: "power3.out"
            });

            gsap.to("#hero-title-1", {
                y: 0,
                duration: 1.2,
                delay: 0.4,
                ease: "power3.out"
            });

            gsap.to("#hero-title-2", {
                y: 0,
                duration: 1.2,
                delay: 0.6,
                ease: "power3.out"
            });

            gsap.to("#hero-desc", {
                opacity: 1,
                duration: 1,
                delay: 0.8,
                ease: "power3.out"
            });

            gsap.to("#hero-cta", {
                opacity: 1,
                duration: 1,
                delay: 1,
                ease: "power3.out"
            });

            // Parallax Hero Background
            gsap.to("#hero-bg", {
                scrollTrigger: {
                    trigger: "body",
                    start: "top top",
                    end: "bottom top",
                    scrub: true
                },
                y: 200,
                scale: 1.2
            });

            // Service Cards Stagger
            gsap.from(".service-card", {
                scrollTrigger: {
                    trigger: "#services",
                    start: "top 80%",
                },
                y: 100,
                opacity: 0,
                duration: 0.8,
                stagger: 0.2,
                ease: "power3.out"
            });

            // Navbar scroll effect
            let lastScroll = 0;
            window.addEventListener('scroll', () => {
                const currentScroll = window.pageYOffset;
                const navbar = document.getElementById('navbar');
                
                if (currentScroll > 100) {
                    navbar.classList.add('py-4');
                    navbar.classList.remove('py-6');
                } else {
                    navbar.classList.add('py-6');
                    navbar.classList.remove('py-4');
                }
                
                lastScroll = currentScroll;
            });
        }

        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
    </script>
</body>
</html>
